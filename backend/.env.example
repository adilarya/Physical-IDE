# backend/.env.example
# Copy this file to backend/.env and fill in real values. Never commit .env.

# ---------------------------------------------------------------------------
# MOCK MODE
# true  = zero API calls, canned responses, no key needed (default)
# false = real Gemini Live API — requires GEMINI_API_KEY below
# ---------------------------------------------------------------------------
MOCK_MODE=true

# ---------------------------------------------------------------------------
# GEMINI API KEY
# Required when MOCK_MODE=false
# Get one at: https://aistudio.google.com/app/apikey
# ---------------------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key-here

# ---------------------------------------------------------------------------
# MODEL — Verification Phase (live, working now)
# gemini-3.1-flash-live-preview handles all vision + audio in live mode.
# One API call sees the board and speaks the verdict natively.
# ---------------------------------------------------------------------------
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview

# ---------------------------------------------------------------------------
# MODELS — Tutorial Phase (Phase 1, not yet built)
# These will be used when the Lego-manual generator is implemented.
# ---------------------------------------------------------------------------
# GEMINI_PLANNER_MODEL=gemini-3.1-pro-preview      # circuit plan generation
# GEMINI_IMAGE_MODEL=imagen-3.0-generate-002        # Lego-style step diagrams
# GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview     # step narration

# ---------------------------------------------------------------------------
# GOOGLE CLOUD PLATFORM
# Required for Cloud Run deployment and Firestore audit trail
# ---------------------------------------------------------------------------
GCP_PROJECT_ID=your-gcp-project-id-here
GCP_REGION=us-central1

GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account-key.json

# ---------------------------------------------------------------------------
# SERVER
# ---------------------------------------------------------------------------
PORT=8080

# ---------------------------------------------------------------------------
# FIRESTORE AUDIT TRAIL
# ---------------------------------------------------------------------------
FIRESTORE_AUDIT_COLLECTION=assembly_audit_log
