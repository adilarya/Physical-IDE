# backend/.env.example
# Copy this file to backend/.env and fill in real values. Never commit .env.

# ---------------------------------------------------------------------------
# MOCK MODE
# true  = zero Gemini API calls, canned responses, no key needed (default)
# false = real Gemini calls, requires GEMINI_API_KEY below
# ---------------------------------------------------------------------------
MOCK_MODE=true

# ---------------------------------------------------------------------------
# GEMINI / VERTEX AI
# Required when MOCK_MODE=false
# Get a key at: https://aistudio.google.com/app/apikey
# ---------------------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key-here

# Generation strategy when MOCK_MODE=false
# parallel   = 3 concurrent calls (text + image + audio) — safer, use this
# single_pass = 1 call requesting all modalities — experimental
GEMINI_STRATEGY=parallel

# ---------------------------------------------------------------------------
# MODEL OVERRIDES (optional — defaults shown)
# Only change these if you need to pin a specific model version
# ---------------------------------------------------------------------------
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=imagen-3.0-generate-002
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts

# ---------------------------------------------------------------------------
# GOOGLE CLOUD PLATFORM
# Required for Cloud Run deployment and Firestore audit trail
# ---------------------------------------------------------------------------
GCP_PROJECT_ID=your-gcp-project-id-here
GCP_REGION=us-central1

# Service account key for local dev only (Cloud Run uses its attached service account)
# Download from: GCP Console -> IAM -> Service Accounts -> Keys -> Add Key -> JSON
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account-key.json

# ---------------------------------------------------------------------------
# SERVER
# ---------------------------------------------------------------------------
PORT=8080

# ---------------------------------------------------------------------------
# FIRESTORE AUDIT TRAIL (Eshwar)
# Firestore collection where assembly verification events are written
# ---------------------------------------------------------------------------
FIRESTORE_AUDIT_COLLECTION=assembly_audit_log
