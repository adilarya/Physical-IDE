# backend/.env  -  copy to .env for local dev. Never commit the real file.

# --- mock mode (default true: zero Gemini calls, no key needed) -------------
MOCK_MODE=true

# --- real Gemini (only read when MOCK_MODE=false) --------------------------
GEMINI_STRATEGY=parallel          # parallel | single_pass
# GEMINI_API_KEY=your-key-here

# --- optional model overrides ----------------------------------------------
# GEMINI_VISION_MODEL=gemini-2.5-flash
# GEMINI_TEXT_MODEL=gemini-2.5-flash
# GEMINI_IMAGE_MODEL=imagen-3.0-generate-002
# GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts

# --- server ----------------------------------------------------------------
PORT=8080
