# frontend/.env  -  optional. Copy to .env to override the backend URL.
# Defaults to ws://localhost:8080/ws/agent when unset.

VITE_WS_URL=ws://localhost:8080/ws/agent

# Production example (Cloud Run):
# VITE_WS_URL=wss://physical-ide-agent-xxxxxxxx-uc.a.run.app/ws/agent

# ATHIF: Set this to true to run the full UI with zero backend dependency.
# The scripted demo beat plays entirely in-browser — no Python, no API keys.
# VITE_MOCK_SOCKET=true
