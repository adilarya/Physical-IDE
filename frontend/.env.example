# frontend/.env.example
# Copy this file to frontend/.env and fill in real values. Never commit .env.

# ---------------------------------------------------------------------------
# BACKEND WEBSOCKET URL
# Local dev default — points at the backend running on your machine
# For production, swap to the Cloud Run URL after Adil deploys
# ---------------------------------------------------------------------------
VITE_WS_URL=ws://localhost:8080/ws/agent

# Production (Cloud Run):
VITE_WS_URL=wss://physical-ide-agent-63v3f5vqjq-uc.a.run.app/ws/agent

# ---------------------------------------------------------------------------
# MOCK SOCKET (Athif)
# true  = full UI runs in-browser with no backend, no Python, no API keys
# false = connects to the real backend via VITE_WS_URL (default)
# ---------------------------------------------------------------------------
VITE_MOCK_SOCKET=false
